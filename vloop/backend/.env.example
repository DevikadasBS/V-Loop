# App mode
DEBUG=true
SECRET_KEY=replace_me_with_a_long_random_secret
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# SMTP sender account used by the app to send reset emails to all users
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your_real_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=V-Loop <your_real_email@gmail.com>
# Frontend page opened from the reset link sent to each user's own email
FRONTEND_RESET_URL=http://127.0.0.1:5500/vloop/frontend/reset-password.html
FRONTEND_LOGIN_URL=http://127.0.0.1:5500/vloop/frontend/login.html
